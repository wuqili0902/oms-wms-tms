# Application
APP_NAME=oms-wms-tms
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=change-this-to-a-secure-random-key
CORS_ORIGINS=["*"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/oms_wms_tms
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/oms_wms_tms

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
